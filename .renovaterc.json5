{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices"
  ],
  "packageRules": [
    // Bundle opentelemetry dependencies in a single update
    {
      "matchPackageNames": [
        "opentelemetry",
        "opentelemetry-otlp",
        "opentelemetry_sdk",
        "opentelemetry-resource-detectors",
        "tracing-opentelemetry",
      ],
      "groupName": "opentelemetry"
    },
    // Don't pin digest in inspircd image tag
    {
      "matchManagers": ["docker-compose"],
      "matchPackageNames": ["inspircd/inspircd-docker"],
      "versioning": "semver",
      "pinDigests": false
    },
    // Don't pin official GitHub Actions versions
    {
      "matchDepTypes": ["action"],
      "matchPackageNames": ["actions/*"],
      "pinDigests": false,
    },
    // Don't pin the images used in the Dockerfile
    {
      "matchDatasources": ["docker"],
      "pinDigests": false
    }
  ]
}
